<section class="page-title">
    <div>
        <span class="eyebrow">{{i18n.jobs.eyebrow}}</span>
        <h1>{{i18n.jobs.heading}}</h1>
        <p>{{i18n.jobs.intro}}</p>
    </div>
</section>

{{#has_flash}}
    <div class="alert ok">{{flash}}</div>
{{/has_flash}}

{{^has_jobs}}
    <p>{{i18n.jobs.empty}}</p>
{{/has_jobs}}

{{#has_jobs}}
    {{#jobs}}
        <div class="card" style="margin-bottom: 10px">
            <h2><strong>{{i18n.jobs.job}}</strong>: <code>{{id}}</code></h2>
            <div><strong>{{i18n.jobs.domain}}</strong> {{domain}}</div>
            <div class="status-{{status_class}}"><strong>{{i18n.jobs.status}}</strong>: {{{status_badge}}}</div>
            <div class="nowrap"><strong>{{i18n.jobs.created}}</strong>: {{created_at}}</div>
            <div>
                {{#has_error}}
                    <span class="alert alert-danger">{{error}}</span><br>
                {{/has_error}}

                {{#has_log}}
                    <pre class="job-log">{{{log}}}</pre>
                {{/has_log}}
            </div>
        </div>
    {{/jobs}}
{{/has_jobs}}

{{#should_refresh}}
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            setTimeout(function () {
                window.location.reload();
            }, 30000);
        });
    </script>
{{/should_refresh}}
