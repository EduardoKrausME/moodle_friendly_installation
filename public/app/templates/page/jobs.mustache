<section class="page-title">
    <div>
        <span class="eyebrow">Automação</span>
        <h1>Fila de instalação</h1>
        <p>Jobs pendentes são executados por <code>root</code> via CRON.</p>
    </div>
</section>

{{#has_flash}}
    <div class="alert ok">{{flash}}</div>
{{/has_flash}}


{{^has_jobs}}
    <p>Nenhum job criado.</p>
{{/has_jobs}}

{{#has_jobs}}
    {{#jobs}}
        <div class="card" style="margin-bottom: 10px">
            <h2><strong>Job</strong>: <code>{{id}}</code></h2>
            <div><strong>Domínio</strong> {{domain}}</div>
            <div class="status-{{status_class}}"><strong>Status</strong>: {{{status_badge}}}</div>
            <div class="nowrap"><strong>Criado</strong>: {{created_at}}</div>
            <div>
                {{#has_error}}
                    <span class="error">{{error}}</span><br>
                {{/has_error}}

                {{#has_log}}
                    <pre class="job-log">{{{log}}}</pre>
                {{/has_log}}
            </div>
        </div>
    {{/jobs}}
{{/has_jobs}}


{{#should_refresh}}
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            setTimeout(function () {
                window.location.reload();
            }, 30000);
        });
    </script>
{{/should_refresh}}
