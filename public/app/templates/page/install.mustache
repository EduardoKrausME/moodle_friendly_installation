<section class="page-title">
    <div>
        <span class="eyebrow">{{i18n.install.eyebrow}}</span>
        <h1>{{i18n.install.heading}}</h1>
        <p>{{i18n.install.intro}}</p>
    </div>
</section>

{{#warnings}}
    <div class="alert warning">{{.}}</div>
{{/warnings}}

{{#moodle_branch_load_failed}}
    <div class="alert warning">
        {{i18n.install.branch_load_failed}}
    </div>
{{/moodle_branch_load_failed}}

{{#errors.domain}}
    <small class="alert alert-danger">{{.}}</small>
{{/errors.domain}}
{{#errors.moodle_branch}}
    <small class="alert alert-danger">{{.}}</small>
{{/errors.moodle_branch}}
{{#errors.admin_user}}
    <small class="alert alert-danger">{{.}}</small>
{{/errors.admin_user}}
{{#errors.admin_pass}}
    <small class="alert alert-danger">{{.}}</small>
{{/errors.admin_pass}}
{{#errors.admin_email}}
    <small class="alert alert-danger">{{.}}</small>
{{/errors.admin_email}}

<form method="post" class="card form">
    <input type="hidden" name="csrf_token" value="{{csrf_token}}">

    <label>
        {{i18n.install.domain}}
        <input type="text" name="domain" placeholder="cliente.mylearn.space" value="{{values.domain}}" required>
        {{#errors.domain}}<small class="alert alert-danger">{{.}}</small>{{/errors.domain}}
    </label>

    <label>
        {{i18n.install.site_fullname}}
        <input type="text" name="site_fullname" placeholder="MyLearn - Cliente" value="{{values.site_fullname}}">
    </label>

    <label>
        {{i18n.install.branch}}
        <select name="moodle_branch" required {{^has_moodle_branches}}disabled{{/has_moodle_branches}}>
            {{#moodle_branches}}
                <option value="{{name}}" {{#selected}}selected{{/selected}}>{{label}}</option>
            {{/moodle_branches}}
            {{^has_moodle_branches}}
                <option value="">{{i18n.install.no_branch}}</option>
            {{/has_moodle_branches}}
        </select>
        {{#errors.moodle_branch}}<small class="alert alert-danger">{{.}}</small>{{/errors.moodle_branch}}
    </label>

    <label>
        {{i18n.install.admin_user}}
        <input type="text" name="admin_user" value="{{values.admin_user}}" required>
        {{#errors.admin_user}}<small class="alert alert-danger">{{.}}</small>{{/errors.admin_user}}
    </label>

    <label>
        {{i18n.install.admin_password}}
        <input type="text" name="admin_pass" required>
        {{#errors.admin_pass}}<small class="alert alert-danger">{{.}}</small>{{/errors.admin_pass}}
    </label>

    <label>
        {{i18n.install.admin_email}}
        <input type="email" name="admin_email" value="{{values.admin_email}}" required>
        {{#errors.admin_email}}<small class="alert alert-danger">{{.}}</small>{{/errors.admin_email}}
    </label>

    <label class="checkbox">
        <input type="checkbox" name="issue_cert" value="1" {{#values.issue_cert}}checked{{/values.issue_cert}}>
        {{i18n.install.issue_cert}}
    </label>

    <div class="form-actions">
        <button type="submit"
                {{^has_moodle_branches}}disabled{{/has_moodle_branches}}>{{i18n.actions.create_install_job}}</button>
    </div>
</form>
