<section class="page-title">
    <div>
        <span class="eyebrow">{{i18n.index.eyebrow}}</span>
        <h1>{{i18n.index.heading}}</h1>
        <p>{{i18n.index.intro}}</p>
    </div>
    <a class="button" href="/install.php">{{i18n.actions.install_moodle}}</a>
</section>

{{#has_flash}}
    <div class="alert ok">{{flash}}</div>
{{/has_flash}}

{{^has_sites}}
    <div class="card empty-state">
        <div class="empty-icon">+</div>
        <h2>{{i18n.index.empty_heading}}</h2>
        <p>{{i18n.index.empty_intro}}</p>
        <a class="button" href="/install.php">{{i18n.actions.install_first_moodle}}</a>
    </div>
{{/has_sites}}

{{#has_sites}}
    <section class="site-grid">
        {{#sites}}
            <article class="site-card">
                <div class="site-card-header">
                    <div>
                        <span class="eyebrow">{{i18n.index.moodle_label}}</span>
                        <h2>{{domain}}</h2>
                    </div>
                    {{{status_badge}}}
                </div>
                <dl class="site-meta">
                    <div>
                        <dt>{{i18n.index.branch}}</dt>
                        <dd>{{moodle_branch}}</dd>
                    </div>
                </dl>
                <a class="button secondary" href="{{details_url}}">{{i18n.actions.view_details}}</a>
            </article>
        {{/sites}}
    </section>
{{/has_sites}}
