<section class="page-title">
    <div>
        <span class="eyebrow">Painel MyLearn</span>
        <h1>Sites Moodle</h1>
        <p>Gerencie instalações, acompanhe status e abra rapidamente cada ambiente Moodle.</p>
    </div>
    <a class="button" href="/install.php">Instalar Moodle</a>
</section>

{{#has_flash}}
    <div class="alert ok">{{flash}}</div>
{{/has_flash}}

{{^has_sites}}
    <div class="card empty-state">
        <div class="empty-icon">+</div>
        <h2>Nenhum Moodle cadastrado ainda</h2>
        <p>Crie a primeira instalação para iniciar o acompanhamento pelo painel.</p>
        <a class="button" href="/install.php">Instalar primeiro Moodle</a>
    </div>
{{/has_sites}}

{{#has_sites}}
    <section class="site-grid">
        {{#sites}}
            <article class="site-card">
                <div class="site-card-header">
                    <div>
                        <span class="eyebrow">Moodle</span>
                        <h2>{{domain}}</h2>
                    </div>
                    {{{status_badge}}}
                </div>
                <dl class="site-meta">
                    <div>
                        <dt>Branch</dt>
                        <dd>{{moodle_branch}}</dd>
                    </div>
                </dl>
                <a class="button secondary" href="{{details_url}}">Ver detalhes</a>
            </article>
        {{/sites}}
    </section>
{{/has_sites}}
